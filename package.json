{
  "name": "inayan-builder-bot",
  "version": "1.0.0",
  "private": true,
  "description": "Simple-to-install, cheap-to-run AI builder agent with deterministic magic-run planning",
  "keywords": [
    "ai builder agent",
    "deterministic planning",
    "magic run",
    "execution-ready blueprint",
    "github research",
    "reddit research",
    "express api",
    "mcp"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/smanthey/InayanBuilderBot.git"
  },
  "homepage": "https://github.com/smanthey/InayanBuilderBot#readme",
  "bugs": {
    "url": "https://github.com/smanthey/InayanBuilderBot/issues"
  },
  "type": "module",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "setup:auto": "node scripts/bootstrap-local.mjs",
    "setup:onboard": "node scripts/setup-onboard.mjs",
    "start:auto": "npm run setup:auto && node src/index.js",
    "start": "node src/index.js",
    "dev": "NODE_ENV=development node --watch src/index.js",
    "dev:auto": "npm run setup:auto && NODE_ENV=development node --watch src/index.js",
    "test": "node --test",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed",
    "lint": "node --check src/index.js && node --check scripts/security-check.mjs",
    "security:check": "node scripts/security-check.mjs",
    "mcp:health": "node scripts/mcp-health-check.js"
  },
  "dependencies": {
    "better-sqlite3": "^11.8.1",
    "express": "^4.21.2",
    "express-rate-limit": "^7.5.1",
    "helmet": "^8.0.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.52.0"
  }
}
