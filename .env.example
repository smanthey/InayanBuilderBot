NODE_ENV=development
PORT=3000
BUILDERBOT_API_KEY=change-me
ALLOWED_ORIGIN=http://localhost:3000
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=60
GITHUB_TOKEN=
GITHUB_PERSONAL_ACCESS_TOKEN=
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=
POSTGRES_DB=postgres
CLAW_ARCHITECT_ROOT=/Users/tatsheen/claw-architect
# builtin (default), auto, or openclaw
EXTERNAL_INDEXING_MODE=builtin
CODE_INDEX_DIR=/Users/tatsheen/.openclaw/shared/.code-index
OPENAI_API_KEY=
OPENAI_CHAT_MODEL=gpt-4o-mini
DEEPSEEK_API_KEY=
DEEPSEEK_CHAT_MODEL=deepseek-chat
ANTHROPIC_API_KEY=
CLAUDE_API_KEY=
ANTHROPIC_CHAT_MODEL=claude-3-5-sonnet-latest
CLAUDE_CHAT_MODEL=claude-3-5-sonnet-latest
GEMINI_API_KEY=
GOOGLE_API_KEY=
GOOGLE_GENAI_API_KEY=
GEMINI_CHAT_MODEL=gemini-1.5-pro
GOOGLE_CHAT_MODEL=gemini-1.5-pro

# Built-in Reddit research system (OpenClaw-free)
REDDIT_USER_AGENT=inayanbuilderbot-reddit/1.0
REDDIT_DEFAULT_SUBREDDITS=AI_Agents,LocalLLaMA,MachineLearning,programming,webdev,OpenAI,ClaudeAI
REDDIT_REQUEST_TIMEOUT_MS=12000
# Optional: JSON array of profile objects [{ "id":"p1","userAgent":"ua","accessToken":"token" }]
REDDIT_AUTH_PROFILES=
# Optional CSV profile fallback inputs
REDDIT_USER_AGENTS=
REDDIT_ACCESS_TOKENS=

# Optional cost overrides for auto-routing (USD per 1k tokens)
OPENAI_COST_INPUT_PER_1K=0.005
OPENAI_COST_OUTPUT_PER_1K=0.015
DEEPSEEK_COST_INPUT_PER_1K=0.0014
DEEPSEEK_COST_OUTPUT_PER_1K=0.0028
ANTHROPIC_COST_INPUT_PER_1K=0.003
ANTHROPIC_COST_OUTPUT_PER_1K=0.015
GEMINI_COST_INPUT_PER_1K=0.00125
GEMINI_COST_OUTPUT_PER_1K=0.005
